{
  "name": "berlindb/wc-core-tables",
  "description": "BerlinDB schemas for WooCommerce's core database tables - auto-generated from a live install to measure structural parity. Not affiliated with or endorsed by WooCommerce or Automattic.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "berlindb/core": "dev-master"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/wp-test-utils": "^1.2",
    "phpstan/phpstan": "^2",
    "szepeviktor/phpstan-wordpress": "^2",
    "phpstan/extension-installer": "^1.4",
    "berlindb/readiness": "dev-master"
  },
  "repositories": {
    "berlindb-core": {
      "type": "vcs",
      "url": "https://github.com/berlindb/core"
    },
    "berlindb-readiness": {
      "type": "vcs",
      "url": "https://github.com/berlindb/readiness"
    }
  },
  "autoload": {
    "psr-4": {
      "WcCoreTables\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WcCoreTables\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse --memory-limit=1G"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
